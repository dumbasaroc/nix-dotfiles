#!/usr/bin/env bash

VERSION="0.0.2"

print_version() {
    echo "NORS - NixOs Rebuild Switch - v${VERSION}"
}

show_usage() {
    echo "Usage: $0 [-h|-v] [-m MESSAGE] [-p PROFILENAME]"
}

show_flags() {
    echo "FLAGS"
    echo "====="
    echo "    -v            Display version info and exit"
    echo "    -h            Display help menu and exit"
    echo "    -m MESSAGE    Use MESSAGE as the git commit message, as opposed to the date/time"
    echo "    -p PROFILE    Regenerate NixOS with the given profile string"
    echo "    -n            No not push or pull to GitHub on this rebuild"
}

show_help() {
    print_version
    echo "Script by Roc"
    echo ""
    show_usage
    echo ""
    show flags
}

DO_NOT_PUSH_PULL_GH=0

## Define flags
## -v => version
## -h => help
## -m => commit message
## -p => commit profile/branch
## -n => do not push/pull to github

while getopts ":vhnm:p:" VARNAME
do
    if [[ "$VARNAME" == "?" ]]; then
        printf "Flag '%s' is not a valid flag for this script.\n" "$OPTARG"
        show_help
        exit 1
    fi

    case "$VARNAME" in
        "v")
            print_version
            exit 0;;
        "h")
            show_help
            exit 0;;
        "m")
            COMMIT_MESSAGE="$OPTARG";;
        "p")
            PROFILE_NAME="--profile-name '$OPTARG'";;
        "n")
            DO_NOT_PUSH_PULL_GH=1;;
    esac
done

if [ $DO_NOT_PUSH_PULL_GH -ne 1 ]; then
    cd /home/roc/.nixos && git pull
    GIT_PULL_EXIT=$?

    if [ $GIT_PULL_EXIT -ne 0 ]; then
        echo "===================================="
        echo " Error occurred in pulling from Git"
        echo "===================================="
        # git diff --name-only --relative | xargs nvim
        exit 1
    fi
fi


cd /home/roc/.nixos/ && git add . && git add -f hardware-configuration.nix
sudo nixos-rebuild switch ${PROFILE_NAME:+--profile-name "$PROFILE_NAME"}
NORS_EXIT_CODE=$?

if [ $NORS_EXIT_CODE -ne 0 ]; then
    echo "============================"
    printf " Exited with error code %03d\n" $NORS_EXIT_CODE
    echo "============================"
    echo ""
    exit 1
fi

# If successful, git commit with either provided message or timestamp
if [ -z "$COMMIT_MESSAGE" ]; then
    COMMIT_MESSAGE="$(date)"
fi

cd /home/roc/.nixos/ && git rm --cached hardware-configuration.nix
cd /home/roc/.nixos/ && git commit -m "$COMMIT_MESSAGE"
if [ $DO_NOT_PUSH_PULL_GH -ne 1 ]; then
    git push
fi
